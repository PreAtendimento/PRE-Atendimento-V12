# ─── Supabase — variáveis normais (não secret) ───────────────────────────────
# Project URL — já pré-configurado, não alterar
SUPABASE_URL=https://yikemdxcswfvmwdvykiw.supabase.co

# String de conexão Postgres via Supabase Pooler (porta 6543)
# Não é secret — pode ser configurado como variável normal
# Onde encontrar: Project Settings → Database → Connection string → URI (Pooler)
# Formato: postgresql://postgres.xxxx:SENHA@aws-0-xx.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ─── Supabase — secrets obrigatórios ─────────────────────────────────────────
# Configurar via aba Secrets do Replit (nunca expor em arquivos)

# Chave pública anon (frontend)
SUPABASE_ANON_KEY=

# Chave de serviço — somente servidor, bypassa RLS
SUPABASE_SERVICE_ROLE_KEY=

# Segredo JWT — Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
PUBLIC_APP_URL=https://your-app.replit.app
