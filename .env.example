# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL  (ex: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Public anon key (safe for frontend — used in /api/config response)
SUPABASE_ANON_KEY=

# Service role key (server-side only — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection URL (Supabase pooler or direct URL)
# Ex: postgres://postgres.xxxx:PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Secret used to sign and verify session tokens (keep this long and random)
SUPABASE_JWT_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
PUBLIC_APP_URL=https://your-app.replit.app
